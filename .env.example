# Copy this to .env and fill in your values

# Render will set DATABASE_URL automatically when you add a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate a strong secret: open terminal and run ->  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# Your frontend URL (the HTML file URL or a hosted URL)
FRONTEND_URL=*

NODE_ENV=production
PORT=4000
